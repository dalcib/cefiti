rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ======================================================
    // FUNÇÕES AUXILIARES
    // ======================================================

    // Verifica se o usuário está autenticado e presente na lista de autorizados
    function isAuthorized() {
      return request.auth != null && exists(/databases/$(database)/documents/configuracoes/geral/usuarios/$(request.auth.token.email.lower()));
    }

    // Verifica se o usuário é administrador
    function isAdmin() {
      return isAuthorized() && get(/databases/$(database)/documents/configuracoes/geral/usuarios/$(request.auth.token.email.lower())).data.perfil == 'administrador';
    }

    // Verifica se uma praga existe
    function pragaExists(pragName) {
      return exists(/databases/$(database)/documents/pragas/$(pragName));
    }

    // Verifica se uma legislação existe
    function legislacaoExists(legId) {
      return exists(/databases/$(database)/documents/legislacoes/$(legId));
    }

    // ======================================================
    // REGRAS POR COLEÇÃO
    // ======================================================

    // 0. USUÁRIOS AUTORIZADOS (Subcoleção em configuracoes/geral/usuarios)
    match /configuracoes/geral/usuarios/{email} {
      allow read: if isAuthorized();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (request.auth.token.email.lower() == email && 
                      !request.resource.data.diff(resource.data).affectedKeys().hasAny(['perfil', 'email']));
    }

    // 1. HOSPEDEIROS
    match /hospedeiros/{hospId} {
      allow read: if isAuthorized();
      allow create, update: if isAuthorized();
      allow delete: if isAdmin(); 
    }

    // 2. LEGISLAÇÕES E TEXTOS
    match /legislacoes/{legId} {
      allow read: if isAuthorized();
      allow create, update: if isAuthorized();
      allow delete: if isAdmin();
    }

    match /leg_texto/{legId} {
      allow read: if isAuthorized();
      allow create, update: if isAuthorized() && legislacaoExists(legId);
      allow delete: if isAdmin();
    }

    // 3. PRAGAS
    match /pragas/{pragName} {
      allow read: if isAuthorized();
      allow create, update: if isAuthorized();
      allow delete: if isAdmin();
    }

    // 4. REGRAS DE TRÂNSITO (RULES)
    match /rules/{ruleId} {
      allow read: if isAuthorized();
      allow create, update: if isAuthorized() && pragaExists(request.resource.data.prag);
      allow delete: if isAuthorized();
    }

    // 5. STATUS MUNICÍPIO
    match /status_municipio/{pragName} {
      allow read: if isAuthorized();
      allow create, update: if isAuthorized() && pragaExists(request.resource.data.praga);
      allow delete: if isAuthorized();
    }
    
    // 6. CONFIGURAÇÕES / CATÁLOGOS
    match /configuracoes/{configId} {
      allow read: if isAuthorized();
      allow write: if isAdmin();
    }
    
    // ======================================================
    // COLEÇÕES ESTÁTICAS
    // ======================================================
    
    match /estados/{estadoId} {
      allow read: if isAuthorized();
      allow write: if false;
    }
    
    match /municipios/{municipioId} {
      allow read: if isAuthorized();
      allow write: if false;
    }
  }
}

{
  "compilerOptions": {
    "paths": {
      "#db": ["./cefiti/src/db.ts"],
      "#db-next": ["./cefiti-new/src/types.d.ts"],
      "#legislacao": ["./cefiti-new/src/types.d.ts"],
      "#municipios": ["./cefiti-new/src/types.d.ts"]
    },
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "sourceMap": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ESNext",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["node"],
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "experimentalDecorators": true,
    "strict": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  },
  "exclude": ["node_modules", "build", "assets"],
  "include": ["cefiti/src", "cefiti-admin/src", "cefiti/test", "cefiti/public/*.db.js", "cefiti-new/src", "cefiti-new/test", "firebase/public/*.js"]
}

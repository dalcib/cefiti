{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CEFiTI Database Schema",
  "type": "object",
  "properties": {
    "hospedeiros": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "nomeSci": {
            "type": "string"
          },
          "nomeVul": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["id", "nomeSci", "nomeVul"]
      },
      "uniqueItems": true
    },
    "pragas": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "prag": {
            "type": "string"
          },
          "pragc": {
            "type": "string"
          },
          "hosp": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["id", "prag", "pragc", "hosp", "files"]
      },
      "uniqueItems": true
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "prag": { "type": "string" },
          "desc": { "type": "string" },
          "status_origem": {
            "type": "array",
            "items": { "type": "string" }
          },
          "status_destino": {
            "type": "array",
            "items": { "type": "string" }
          },
          "part": {
            "type": "array",
            "items": { "type": "string" }
          },
          "exig": {
            "type": "array",
            "items": { "type": "string" }
          },
          "leg": { "type": "string" }
        },
        "required": ["prag", "desc", "status_origem", "status_destino", "part", "exig", "leg"]
      }
    },
    "legislacoes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "leg": {
            "type": "string"
          },
          "data": {
            "type": "string"
          }
        },
        "required": ["id", "leg", "data"]
      },
      "uniqueItems": true
    },
    "estados": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "ibge": {
            "type": "integer"
          },
          "UF": {
            "type": "string"
          },
          "estado": {
            "type": "string"
          }
        },
        "required": ["ibge", "UF", "estado"]
      }
    },
    "status_municipio": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "praga": {
            "type": "string"
          },
          "status": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "status_fitossanitário": {
                  "type": "string"
                },
                "estados": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "uf": {
                        "type": "string"
                      },
                      "ibge": {
                        "type": "integer"
                      },
                      "municipios": {
                        "type": "array",
                        "items": {
                          "type": "integer"
                        }
                      }
                    },
                    "required": ["uf", "ibge", "municipios"]
                  }
                }
              },
              "required": ["status_fitossanitário", "estados"]
            }
          }
        },
        "required": ["praga", "status"]
      }
    },
    "dbVersion": {
      "type": "integer"
    }
  },
  "required": [
    "hospedeiros",
    "pragas",
    "rules",
    "legislacoes",
    "estados",
    "status_municipio",
    "dbVersion"
  ]
}
